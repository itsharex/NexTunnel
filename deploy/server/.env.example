# NexTunnel 服务端一键部署配置示例
# 复制为 deploy/server/.env 后，install.sh/install.ps1 会先读取该文件。
# 命令行参数优先级最高，其次为环境变量，再其次为本文件。

# Release 包来源。默认仓库对应 https://github.com/Lee-zg/frp-plus/releases/latest/download
NEXTUNNEL_REPOSITORY=Lee-zg/frp-plus
NEXTUNNEL_VERSION=latest
NEXTUNNEL_RELEASE_BASE_URL=
NEXTUNNEL_PACKAGE_URL=
NEXTUNNEL_PACKAGE_SHA256=
NEXTUNNEL_ARCH=

# Linux systemd 安装路径；Windows PowerShell 会默认使用 ProgramData，可用同名变量覆盖。
NEXTUNNEL_INSTALL_DIR=/opt/nextunnel
NEXTUNNEL_CONFIG_DIR=/etc/nextunnel
NEXTUNNEL_DATA_DIR=/var/lib/nextunnel
NEXTUNNEL_SERVICE_USER=nextunnel
NEXTUNNEL_SERVICE_GROUP=nextunnel

# 对外访问地址。生产环境建议填写公网 IP 或域名。
NEXTUNNEL_PUBLIC_HOST=127.0.0.1

# Relay 连接配置
RELAY_BIND=0.0.0.0
RELAY_CONTROL_PORT=7000
RELAY_QUIC_PORT=7443
RELAY_AUTH_TOKEN=change-me-relay-token
RELAY_REQUIRE_AUTH=true
RELAY_STATS_INTERVAL=30s

# Control Plane 配置
CONTROL_PLANE_PORT=9090
CONTROL_PLANE_API_TOKEN=change-me-control-token

# NAT Detector 配置
NAT_PRIMARY_ADDR=0.0.0.0
NAT_ALT_ADDR=127.0.0.1
NAT_PORT=3478
NAT_REALM=nextunnel.local

# 1Panel/Compose 镜像部署模板使用。生产一键脚本不依赖该镜像。
COMPOSE_PROJECT_NAME=nextunnel
NEXTUNNEL_IMAGE=ghcr.io/lee-zg/frp-plus/server:latest
NEXTUNNEL_NETWORK=nextunnel-net
